{
  "name": "kaki-quiz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "wrangler dev --port 8787",
    "dev:web": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "db:migrate": "wrangler d1 migrations apply kaki-quiz-db --local",
    "db:seed": "node scripts/seed.mjs",
    "db:reset": "rm -rf .wrangler/state && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250110.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wrangler": "^3.99.0"
  }
}
